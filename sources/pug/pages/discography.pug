extends  ../_skeleton

//- Includes
include ../components/_ui-thumbnail


block variables
	- var activeCategory = 'gallery'
	- var pageName = 'Discography'

block page  
	// Page Header
	+header-classic: include ../includes/_aside-navbar-classic

	+breadcrumbs({
		category: activeCategory,
		path: [pageName],
		bgImage: 'bg-about-1'
	})

	// Grid Gallery
	section.section.section-xl.bg-default
		.container.isotope-wrap
			.isotope-filters
				//- Isotope Filters
				button.isotope-filters-toggle.button.button-sm.button-icon.button-icon-right.button-default-outline(data-custom-toggle='.isotope-filters-list', data-custom-toggle-hide-on-blur='true')
					span.icon.mdi.mdi-chevron-down
					| Filter

				.isotope-filters-list-wrap
					ul.isotope-filters-list
						li: a.active(href='#', data-isotope-filter='*') all Years 
						li: a(href='#', data-isotope-filter='Type 1') 2020
						li: a(href='#', data-isotope-filter='Type 2') 2018

			.row.row-30.isotope(data-lightgallery='group')
				.col-sm-6.col-lg-4.isotope-item(data-filter='Type 1')
					+thumbnail-classic({
						gallery: true,
						discography: true,
						img: 'home-1-370x315',
						title: 'Bandio EP',
						year: '2020'
					})
				.col-sm-6.col-lg-4.isotope-item(data-filter='Type 1')
					+thumbnail-classic({
						gallery: true,
						discography: true,
						img: 'home-2-370x315',
						title: 'Bandio Square',
						year: '2020'
					})
				.col-sm-6.col-lg-4.isotope-item(data-filter='Type 2')
					+thumbnail-classic({
						gallery: true,
						discography: true,
						img: 'home-3-370x315',
						title: 'just a Beginning',
						year: '2018'
					})
				.col-sm-6.col-lg-4.isotope-item(data-filter='Type 1')
					+thumbnail-classic({
						gallery: true,
						discography: true,
						img: 'home-4-370x315',
						title: 'sounds of the Streets',
						year: '2020'
					})
				.col-sm-6.col-lg-4.isotope-item(data-filter='Type 2')
					+thumbnail-classic({
						gallery: true,
						discography: true,
						img: 'home-5-370x315',
						title: 'Stay Wild',
						year: '2018'
					})
				.col-sm-6.col-lg-4.isotope-item(data-filter='Type 2')
					+thumbnail-classic({
						gallery: true,
						discography: true,
						img: 'home-6-370x315',
						title: 'M.A.D',
						year: '2018'
					})
	='\n'

	// Page Footer
	include ../sections/_footer-classic