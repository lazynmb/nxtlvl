mixin post-classic(obj)
	// Post Classic
	article.post.post-classic.box-md( class= obj.mod )&attributes(attributes)
		a.post-classic-figure(href=links.post): +jpg( obj.img )
		.post-classic-content
			.post-classic-time: time( datetime= obj.time.datetime )= obj.time.dateText
			h5.post-classic-title: a(href=links.post)=obj.title
			p.post-classic-text= obj.text ? obj.text : 'A fridge full of organic vegetables purchased or harvested with the best of intentions, and then life gets busy'

mixin post-modern(obj)
	// Post Modern
	article.post.post-modern.box-xxl( class= obj.mod )&attributes(attributes)
		.post-modern-panel
			div: a.post-modern-tag( href='#' )=obj.tag
			div: time.post-modern-time( datetime= obj.time.datetime )= obj.time.dateText
		h3.post-modern-title: a(href=links.post)=obj.title
		a.post-modern-figure(href=links.post): +jpg( obj.img )
		p.post-modern-text= obj.text ? obj.text : 'Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua. At vero eos et accusam et justo duo dolores et ea rebum. Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor sit amet. Lorem ipsum dolor sit amet'
		a.post-modern-link(href=links.post) Read more

mixin post-creative(obj)
	// Post Creative
	article.post.post-creative( class= obj.mod )&attributes(attributes)
		a.post-creative-figure(href=links.post): +jpg( obj.img )
		.post-creative-content
			h5.post-creative-title: a(href=links.post)!=obj.title
			.post-creative-time: time( datetime= obj.time.datetime )= obj.time.dateText

