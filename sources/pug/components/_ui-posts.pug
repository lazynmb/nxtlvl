//- Post side
	@param {object} data - data object
	@param {string} data.img - post image
	@param {string} data.title - post title
	@param {string} data.text - post text
mixin post-side( data )
	// Post side
	.post-side&attributes( attributes )
		a.post-side-media( href='blog-post.html' )
			+img( data.img ).post-side-img
		.post-side-body
			.post-side-date= data.date
			h3.title-modify.post-side-title: a( href='blog-post.html' )= data.title
			.post-side-text= data.text
			a.post-side-link.link-underline( href='blog-post.html' ) More