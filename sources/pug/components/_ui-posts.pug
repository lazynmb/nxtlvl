mixin post-minimal(obj)
	// Post Minimal
	article.post.post-minimal( class= obj.mod )&attributes(attributes)
		.unit.unit-spacing-sm( class= obj.unit )
			.unit-left: a.post-minimal-figure(href=links.post): +jpg( obj.img )
			.unit-body
				p.post-minimal-title: a(href=links.post)=obj.title
				.post-minimal-time: time( datetime= obj.time.datetime )= obj.time.dateText

